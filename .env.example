# 실제 키는 .env 파일에만 설정하고 Git에는 절대 올리지 않는다.
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_CONNECT_TIMEOUT_SECONDS=1
CEREBRAS_READ_TIMEOUT_SECONDS=15
LLM_MAX_ATTEMPTS=2
REPLY_QUALITY_MAX_ATTEMPTS=2
REPLY_SIMILARITY_THRESHOLD=0.92
REPLY_CANDIDATE_MIN_SCORE=65
REPLY_DIVERSITY_MIN_SCORE=55
REPLY_PRIVACY_DIVERSITY_MIN_SCORE=40
REPLY_JUDGE_FAIL_OPEN=true
AFTERMATH_QUALITY_MAX_ATTEMPTS=2
LLM_MAX_COMPLETION_TOKENS=1400
LLM_LENGTH_RETRY_COMPLETION_TOKENS=1800
LLM_TEMPERATURE=0.7
CEREBRAS_REASONING_EFFORT=low
LLM_MAX_MEMORY_CHARS=12000
INTERNAL_SERVICE_TOKEN=
